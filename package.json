{
  "name": "emberanvil",
  "version": "1.0.0",
  "private": "false",
  "description": "This template should help get you started developing with Vue 3 in Vite.\r <hr>",
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "oxlint --fix && eslint --fix .",
    "lint:ci": "oxlint && eslint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "fix": "oxlint --fix && eslint --fix . && oxfmt --write .",
    "sitemap": "node scripts/generate-sitemap.js",
    "build:sitemap": "npm run build && npm run sitemap",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@prettier/plugin-oxc": "^0.1.4",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.5.0",
    "eslint-plugin-oxlint": "^1.70.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "prettier": "^3.8.4",
    "sitemap": "^9.0.1",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
